AWSTemplateFormatVersion: '2010-09-09'
Description: Deploy PostgreSQL 17 RDS in existing VPC/subnets with custom parameter and SG's

Parameters:
  VPCID:
    Type: AWS::EC2::VPC::Id
    Description: Existing VPC ID
    Default: vpc-012ff

  Subnet1:
    Type: AWS::EC2::Subnet::Id
    Description: Database Subnet 2a
    Default: subnet-987z012

  Subnet2:
    Type: AWS::EC2::Subnet::Id
    Description: Database Subnet 2b
    Default: subnet-012a012

  DBInstanceType:
    Type: String
    Description: RDS instance type
    Default: db.t3.large # Requirement as of step 4 (The safe default)

  DBUsername:
    Type: String
    Default: admin
    Description: Master username for RDS

  DBPassword:
    Type: String
    Description: Master user password (passed via GitHub Secrets)
    NoEcho: true

Resources:
  # Requirement A.2: Security Group restricted to Corporate Range
  RdsSecurityGroup:
    Type: AWS::EC2::SecurityGroup
    Properties:
      GroupDescription: Security group for RDS PostgreSQL
      VpcId: !Ref VPCID
      SecurityGroupIngress:
        - IpProtocol: tcp
          FromPort: 5432
          ToPort: 5432
          CidrIp: 10.160.0.0/20 # Corporate network only

  # Requirement A.1: Subnet Group for placement
  MyDBSubnetGroup:
    Type: AWS::RDS::DBSubnetGroup
    Properties:
      DBSubnetGroupDescription: Subnets for RDS deployment
      SubnetIds:
        - !Ref Subnet1
        - !Ref Subnet2

  # Requirement A.3: Custom Parameter Group
  PostgresParameterGroup:
    Type: AWS::RDS::DBParameterGroup
    Properties:
      Description: Custom PostgreSQL 17 parameter group
      Family: postgres17
      Parameters:
        shared_buffers: '2097152' # Non-default parameter example

  # Requirement A.1: RDS Instance
  MyPostgresDB:
    Type: AWS::RDS::DBInstance
    Properties:
      DBInstanceIdentifier: my-postgres-db
      Engine: postgres
      EngineVersion: '17.1' #minor version
      DBInstanceClass: !Ref DBInstanceType
      AllocatedStorage: 20
      StorageEncrypted: true # Requirement A.1.4
      MasterUsername: !Ref DBUsername
      MasterUserPassword: !Ref DBPassword
      VPCSecurityGroups:
        - !Ref RdsSecurityGroup
      DBSubnetGroupName: !Ref MyDBSubnetGroup
      DBParameterGroupName: !Ref PostgresParameterGroup
      MultiAZ: false # Requirement A.1.3 (Single-AZ)
      PubliclyAccessible: false
      BackupRetentionPeriod: 7
      DeletionProtection: true
